<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Купон ставки — Англия vs Аргентина</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #0b0e14;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            padding: 12px;
        }

        .ticket {
            max-width: 380px;
            width: 100%;
            background: #1a1f2a;
            border-radius: 28px;
            padding: 24px 20px 30px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8), 0 0 0 1px rgba(255, 255, 255, 0.04);
            color: #fff;
            position: relative;
            transition: transform 0.15s;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .brand-icon {
            background: #2d7a3e;
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 14px;
            color: #fff;
        }

        .brand-name {
            font-weight: 600;
            font-size: 17px;
            letter-spacing: 0.3px;
        }

        .status-badge {
            background: #2d7a3e;
            padding: 6px 14px;
            border-radius: 30px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            color: #b3ffc6;
            box-shadow: 0 0 12px rgba(45, 122, 62, 0.3);
        }

        .event {
            background: #232a36;
            border-radius: 16px;
            padding: 16px 16px 12px;
            margin-bottom: 18px;
        }

        .event-league {
            font-size: 11px;
            color: #8892a5;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-bottom: 8px;
        }

        .event-teams {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 600;
            font-size: 17px;
        }

        .team {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .team-flag {
            font-size: 22px;
        }

        .vs {
            color: #5d687c;
            font-size: 13px;
            font-weight: 400;
        }

        .event-meta {
            display: flex;
            justify-content: space-between;
            margin-top: 10px;
            font-size: 12px;
            color: #8892a5;
            border-top: 1px solid #2f3847;
            padding-top: 10px;
        }

        .bet-details {
            background: #0f131c;
            border-radius: 14px;
            padding: 16px;
            margin-bottom: 18px;
        }

        .bet-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid #1f2733;
        }

        .bet-row:last-child {
            border-bottom: none;
        }

        .bet-label {
            color: #8892a5;
            font-size: 14px;
        }

        .bet-value {
            font-weight: 600;
            font-size: 15px;
        }

        .bet-value.highlight {
            color: #7acf8a;
        }

        .bet-value.amount {
            font-size: 18px;
            color: #fff;
        }

        .bet-value.odds {
            color: #ffb347;
        }

        .payout {
            background: linear-gradient(135deg, #1f2a1f, #152015);
            border-radius: 14px;
            padding: 16px;
            text-align: center;
            border: 1px solid #2d7a3e50;
            margin-bottom: 20px;
        }

        .payout-label {
            font-size: 13px;
            color: #8892a5;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .payout-amount {
            font-size: 32px;
            font-weight: 700;
            color: #7acf8a;
            margin-top: 4px;
            text-shadow: 0 0 20px rgba(45, 122, 62, 0.25);
        }

        .payout-amount small {
            font-size: 18px;
            font-weight: 400;
            color: #b3ffc6;
        }

        .btn-accept {
            width: 100%;
            background: #2d7a3e;
            border: none;
            padding: 16px;
            border-radius: 40px;
            font-weight: 700;
            font-size: 17px;
            color: #fff;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            cursor: default;
            box-shadow: 0 8px 24px rgba(45, 122, 62, 0.35);
            letter-spacing: 0.3px;
        }

        .btn-accept .check {
            font-size: 20px;
        }

        .footer {
            display: flex;
            justify-content: space-between;
            margin-top: 16px;
            font-size: 11px;
            color: #4d5a6e;
            letter-spacing: 0.2px;
        }

        .footer span {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        @media (max-width: 400px) {
            .ticket {
                padding: 18px 14px 22px;
            }
            .event-teams {
                font-size: 15px;
            }
            .payout-amount {
                font-size: 26px;
            }
        }

        .ticket::before {
            content: '';
            position: absolute;
            top: 12px;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 4px;
            background: #2d7a3e;
            border-radius: 4px;
            opacity: 0.3;
        }
    </style>
</head>
<body>

    <div class="ticket">

        <div class="header">
            <div class="brand">
                <div class="brand-icon">⚡</div>
                <span class="brand-name">BetPro</span>
            </div>
            <div class="status-badge">✔ Принята</div>
        </div>

        <div class="event">
            <div class="event-league">🏆 ЧМ-2026 · 1/2 финала</div>
            <div class="event-teams">
                <span class="team">
                    <span class="team-flag">🏴󠁧󠁢󠁥󠁮󠁧󠁿</span> Англия
                </span>
                <span class="vs">vs</span>
                <span class="team">
                    Аргентина <span class="team-flag">🇦🇷</span>
                </span>
            </div>
            <div class="event-meta">
                <span>📅 12.07.2026 22:00</span>
                <span>⚽ Ставка: П2 (победа Аргентины)</span>
            </div>
        </div>

        <div class="bet-details">
            <div class="bet-row">
                <span class="bet-label">Сумма ставки</span>
                <span class="bet-value amount">50 000 ₽</span>
            </div>
            <div class="bet-row">
                <span class="bet-label">Коэффициент</span>
                <span class="bet-value odds">5.30</span>
            </div>
            <div class="bet-row">
                <span class="bet-label">Тип</span>
                <span class="bet-value">Ординар</span>
            </div>
            <div class="bet-row">
                <span class="bet-label">Исход</span>
                <span class="bet-value highlight">Победа Аргентины (П2)</span>
            </div>
        </div>

        <div class="payout">
            <div class="payout-label">💎 Потенциальный выигрыш</div>
            <div class="payout-amount">265 000 <small>₽</small></div>
        </div>

        <div class="btn-accept">
            <span class="check">✅</span> Ставка принята
        </div>

        <div class="footer">
            <span>🆔 #ENGARG-7723</span>
            <span>⏱ 12.07.2026 21:18</span>
        </div>

    </div>

</body>
</html>
